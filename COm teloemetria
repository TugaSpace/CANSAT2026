#include <Arduino.h>
#include <Wire.h>
#include <FreeRTOS.h>
#include <task.h>
#include <semphr.h>
#include <DFRobot_BMP3XX.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BNO055.h>
#include <utility/imumaths.h>

// Instâncias dos BMP388
DFRobot_BMP388_I2C bmp_76(&Wire, 0x76);
DFRobot_BMP388_I2C bmp_77(&Wire, 0x77);

// Instância do BNO055 (ID 55, endereço padrão 0x28)
Adafruit_BNO055 bno = Adafruit_BNO055(55, 0x29);

// Mutex para o barramento I2C
SemaphoreHandle_t i2c_mutex;

// Variáveis globais para o Filtro Complementar (Fusao de Dados)
volatile float baro_altitude = 0.0f;
volatile bool baro_inicializado = false;
float base_baro_alt = 0.0f;

// Variáveis globais para telemetria dos BMP388
volatile float bmp76_temp = 0.0f, bmp76_press = 0.0f, bmp76_alt = 0.0f;
volatile float bmp77_temp = 0.0f, bmp77_press = 0.0f, bmp77_alt = 0.0f;

// Variáveis globais para telemetria do BNO055
volatile float bno_pos_x = 0.0f, bno_pos_y = 0.0f, bno_pos_z = 0.0f;
volatile float bno_yaw = 0.0f;
volatile uint8_t bno_sys_calib = 0;

// Task para BMP388 no 0x76
void TaskLeituraBMP_76(void *pvParameters) {
  for (;;) {
    if (xSemaphoreTake(i2c_mutex, portMAX_DELAY) == pdTRUE) {
      float temp = bmp_76.readTempC();
      float press = bmp_76.readPressPa() / 100.0;
      float alt = bmp_76.readAltitudeM();

      // Capturar a primeira leitura como o ponto "Zero" (Chao)
      if (!baro_inicializado) {
        base_baro_alt = alt;
        baro_inicializado = true;
      }
      baro_altitude = alt - base_baro_alt; // Altitude relativa

      // Guardar para a linha de telemetria conjunta
      bmp76_temp = temp;
      bmp76_press = press;
      bmp76_alt = alt;

      // Leituras comentadas para manter o terminal Serial limpo para a telemetria
      // Serial.print("--- BMP388 (0x76) @ "); Serial.print(millis()); Serial.println(" ms ---");
      // Serial.print("Temperatura: "); Serial.print(temp); Serial.println(" *C");
      // Serial.print("Pressao: "); Serial.print(press); Serial.println(" hPa");
      // Serial.print("Altitude: "); Serial.print(alt); Serial.println(" m\n");

      xSemaphoreGive(i2c_mutex);
    }
    vTaskDelay(pdMS_TO_TICKS(100)); // Reduzido para 100ms (10Hz) para suavizar a fusao de dados
  }
}

// Task para BMP388 no 0x77
void TaskLeituraBMP_77(void *pvParameters) {
  vTaskDelay(pdMS_TO_TICKS(333)); // Pequeno desfasamento
  for (;;) {
    if (xSemaphoreTake(i2c_mutex, portMAX_DELAY) == pdTRUE) {
      float temp = bmp_77.readTempC();
      float press = bmp_77.readPressPa() / 100.0; 
      float alt = bmp_77.readAltitudeM();

      // Guardar para a linha de telemetria conjunta
      bmp77_temp = temp;
      bmp77_press = press;
      bmp77_alt = alt;

      // Leituras comentadas para manter o terminal Serial limpo para a telemetria
      // Serial.print("--- BMP388 (0x77) @ "); Serial.print(millis()); Serial.println(" ms ---");
      // Serial.print("Temperatura: "); Serial.print(temp); Serial.println(" *C");
      // Serial.print("Pressao: "); Serial.print(press); Serial.println(" hPa");
      // Serial.print("Altitude: "); Serial.print(alt); Serial.println(" m\n");

      xSemaphoreGive(i2c_mutex);
    }
    vTaskDelay(pdMS_TO_TICKS(1000));
  }
}

// Task para BNO055
void TaskLeituraBNO055(void *pvParameters) {
  vTaskDelay(pdMS_TO_TICKS(666)); // Desfasamento para não colidir no arranque
  
  // Variáveis para a dupla integração (velocidade e deslocamento)
  float vel_x = 0.0f, vel_y = 0.0f, vel_z = 0.0f;
  float pos_x = 0.0f, pos_y = 0.0f, pos_z = 0.0f;
  float last_ax = 0.0f, last_ay = 0.0f, last_az = 0.0f;       // Histórico para Integração Trapezoidal
  float last_vel_x = 0.0f, last_vel_y = 0.0f, last_vel_z = 0.0f; // Histórico para Integração Trapezoidal
  float bias_x = 0.0f, bias_y = 0.0f, bias_z = 0.0f;         // Erro estático contínuo (Bias)
  uint32_t tempo_parado = 0;                  // Temporizador para reset automático
  uint32_t last_time = millis();

  for (;;) {
    if (xSemaphoreTake(i2c_mutex, portMAX_DELAY) == pdTRUE) {
      sensors_event_t orientationData, linearAccelData;
      bno.getEvent(&orientationData, Adafruit_BNO055::VECTOR_EULER);
      bno.getEvent(&linearAccelData, Adafruit_BNO055::VECTOR_LINEARACCEL); // Aceleração sem gravidade
      
      // Ler o Quaternião de orientação atual do sensor
      imu::Quaternion quat = bno.getQuat();

      // Ler o estado de calibração interno do sensor
      uint8_t system, gyro, accel, mag = 0;
      bno.getCalibration(&system, &gyro, &accel, &mag);

      // Cálculo do dt (intervalo de tempo em segundos desde a última leitura)
      uint32_t current_time = millis();
      float dt = (current_time - last_time) / 1000.0f;
      last_time = current_time;

      // 1. Aceleração no referencial local (eixos do próprio sensor)
      float loc_ax = linearAccelData.acceleration.x;
      float loc_ay = linearAccelData.acceleration.y;
      float loc_az = linearAccelData.acceleration.z; // Necessário para a matemática de rotação

      // 2. Extrair os componentes do Quaternião (w, x, y, z)
      float qw = quat.w(), qx = quat.x(), qy = quat.y(), qz = quat.z();

      // 3. Rotação do vetor usando a Matriz de Rotação baseada no Quaternião
      // Isto converte a aceleração para o referencial fixo da Terra (Norte/Este/Cima)
      float raw_ax = loc_ax * (1.0f - 2.0f*(qy*qy + qz*qz)) + loc_ay * (2.0f*(qx*qy - qw*qz))       + loc_az * (2.0f*(qx*qz + qw*qy));
      float raw_ay = loc_ax * (2.0f*(qx*qy + qw*qz))       + loc_ay * (1.0f - 2.0f*(qx*qx + qz*qz)) + loc_az * (2.0f*(qy*qz - qw*qx));
      float raw_az = loc_ax * (2.0f*(qx*qz - qw*qy))       + loc_ay * (2.0f*(qy*qz + qw*qx))       + loc_az * (1.0f - 2.0f*(qx*qx + qy*qy));
      
      // --- SALVAGUARDA DE INCLINAÇÃO (GRAVIDADE) ---
      // Se o sensor não estiver minimamente calibrado (Sys == 0), o cálculo da gravidade interna
      // pode falhar. Ignoramos as leituras para evitar que a inclinação injete erros colossais.
      if (system == 0) {
        raw_ax = 0.0f;
        raw_ay = 0.0f;
        raw_az = 0.0f;
      }

      // --- 1. FILTRO DINÂMICO DE BIAS (Auto-Calibração Contínua) ---
      // Se a aceleração é baixa, assumimos que está parado. O valor que vemos é o "ruído base".
      // Usamos uma média móvel exponencial para aprender este ruído lentamente.
      if (abs(raw_ax) < 0.25f && abs(raw_ay) < 0.25f && abs(raw_az) < 0.25f) {
        bias_x = (0.95f * bias_x) + (0.05f * raw_ax);
        bias_y = (0.95f * bias_y) + (0.05f * raw_ay);
        bias_z = (0.95f * bias_z) + (0.05f * raw_az);
      }

      // Subtrair o "ruído base" da aceleração lida
      float ax = raw_ax - bias_x;
      float ay = raw_ay - bias_y;
      float az = raw_az - bias_z;
      
      // Como subtraímos o ruído matematicamente, podemos ser muito mais sensíveis aos movimentos reais!
      if (abs(ax) < 0.08f) ax = 0.0f;
      if (abs(ay) < 0.08f) ay = 0.0f;
      if (abs(az) < 0.08f) az = 0.0f;

      // --- 2. INTEGRAÇÃO TRAPEZOIDAL DA VELOCIDADE ---
      // A média entre a aceleração anterior e a atual x tempo
      vel_x += ((ax + last_ax) / 2.0f) * dt;
      vel_y += ((ay + last_ay) / 2.0f) * dt;
      vel_z += ((az + last_az) / 2.0f) * dt;

      // --- O SEGREDO ESTÁ AQUI: Aplicação de "Atrito" (Leaky Integrator) ---
      if (ax == 0.0f) {
        vel_x *= 0.80f; // Travão ligeiramente mais forte
      } else {
        vel_x *= 0.98f; 
      }

      if (ay == 0.0f) {
        vel_y *= 0.80f;
      } else {
        vel_y *= 0.98f;
      }
      
      if (az == 0.0f) {
        vel_z *= 0.80f;
      } else {
        vel_z *= 0.98f;
      }

      // Cortar a "velocidade zombie" (valores residuais minúsculos)
      if (abs(vel_x) < 0.01f) vel_x = 0.0f;
      if (abs(vel_y) < 0.01f) vel_y = 0.0f;
      if (abs(vel_z) < 0.01f) vel_z = 0.0f;

      // --- 3. RESET AUTOMÁTICO DE POSIÇÃO (Anti-Deriva Longa) ---
      // Se o dispositivo não registar aceleração por mais de 5 segundos contínuos,
      // assumimos que o movimento terminou. Zeramos a posição para limpar a deriva acumulada.
      if (ax == 0.0f && ay == 0.0f && az == 0.0f) {
        tempo_parado += (current_time - last_time);
        if (tempo_parado > 5000) { // 5000 ms = 5 segundos perfeitamente parado
          pos_x = 0.0f;
          pos_y = 0.0f;
          pos_z = 0.0f;
        }
      } else {
        tempo_parado = 0;
      }

      // --- 4. INTEGRAÇÃO TRAPEZOIDAL DA POSIÇÃO ---
      pos_x += ((vel_x + last_vel_x) / 2.0f) * dt;
      pos_y += ((vel_y + last_vel_y) / 2.0f) * dt;
      
      // --- 5. FILTRO COMPLEMENTAR PARA O EIXO Z ---
      // Calcular primeiro a estimativa inercial (rápida, mas com deriva)
      float pos_z_imu = pos_z + ((vel_z + last_vel_z) / 2.0f) * dt;
      
      if (baro_inicializado) {
        // 98% confianca no IMU (movimento suave e rapido) | 2% no Barometro (ancora estatica)
        float alpha = 0.98f;
        pos_z = (alpha * pos_z_imu) + ((1.0f - alpha) * baro_altitude);
      } else {
        pos_z = pos_z_imu; // Salvaguarda antes de o barometro ter dados
      }

      // Guardar valores atuais para servirem de "anterior" no próximo ciclo
      last_ax = ax;
      last_ay = ay;
      last_az = az;
      last_vel_x = vel_x;
      last_vel_y = vel_y;
      last_vel_z = vel_z;

      // --- 6. ATUALIZAR DADOS PARA A TELEMETRIA ---
      bno_pos_x = pos_x;
      bno_pos_y = pos_y;
      bno_pos_z = pos_z;
      bno_yaw = orientationData.orientation.x;
      bno_sys_calib = system;

      xSemaphoreGive(i2c_mutex);
    }
    vTaskDelay(pdMS_TO_TICKS(10)); // Reduzido para 10ms (100Hz) para melhorar a precisão da integração
  }
}

// Task dedicada apenas ao envio de telemetria
void TaskTelemetria(void *pvParameters) {
  // Guardar o tempo atual para referencial de ritmo
  TickType_t xLastWakeTime = xTaskGetTickCount();
  // Frequência absoluta desejada: 500 milissegundos (2Hz)
  const TickType_t xFrequency = pdMS_TO_TICKS(500);

  for (;;) {
    // Formato CSV compatível com Excel e Serial Plotter (Valores separados por vírgula)
    Serial.print("TELEMETRIA,");
    Serial.print(millis()); Serial.print(",");
    Serial.print(bno_pos_x, 3); Serial.print(",");
    Serial.print(bno_pos_y, 3); Serial.print(",");
    Serial.print(bno_pos_z, 3); Serial.print(",");
    Serial.print(baro_altitude, 3); Serial.print(",");
    Serial.print(bno_yaw, 2); Serial.print(",");
    Serial.print(bno_sys_calib); Serial.print(",");
    Serial.print(bmp76_temp, 2); Serial.print(",");
    Serial.print(bmp76_press, 2); Serial.print(",");
    Serial.print(bmp76_alt, 2); Serial.print(",");
    Serial.print(bmp77_temp, 2); Serial.print(",");
    Serial.print(bmp77_press, 2); Serial.print(",");
    Serial.println(bmp77_alt, 2);

    // Garante que o próximo ciclo inicia rigorosamente 500ms após o anterior
    vTaskDelayUntil(&xLastWakeTime, xFrequency); 
  }
}

void setup() {
  Serial.begin(115200);
  
  // Espera no máximo 1.5 segundos pela porta Serial, mas AVANÇA se não houver cabo USB ligado!
  uint32_t t = millis();
  while (!Serial && (millis() - t < 1500)); 
  
  Wire.begin();
  Serial.println("A iniciar sensores...\n");

  // Inicializar o Mutex
  i2c_mutex = xSemaphoreCreateMutex();

  if (bmp_76.begin() != 0) {
    Serial.println("Falha ao inicializar o BMP388 no 0x76!");
  } else {
    Serial.println("BMP388 (0x76) inicializado com sucesso!");
  }

  if (bmp_77.begin() != 0) {
    Serial.println("Falha ao inicializar o BMP388 no 0x77!");
  } else {
    Serial.println("BMP388 (0x77) inicializado com sucesso!");
  }
  
  // O BNO055 precisa de cerca de 400ms a 500ms depois de ligar a energia para arrancar totalmente
  delay(500);

  // Inicializar o BNO055
  if (!bno.begin()) {
    Serial.println("Falha ao inicializar o BNO055! Verifica as ligacoes e o endereco I2C.");
  } else {
    Serial.println("BNO055 inicializado com sucesso!");
    bno.setExtCrystalUse(true); // O uso do cristal externo e recomendado para estabilidade
  }

  // Criar as Tasks (não são necessários mais atrasos, o FreeRTOS gere as temporizações daqui para a frente)
  xTaskCreate(TaskLeituraBMP_76, "Task 76", 1024, NULL, 1, NULL);
  xTaskCreate(TaskLeituraBMP_77, "Task 77", 1024, NULL, 1, NULL);
  
  // Subimos a prioridade da Task BNO para 2, pois o cálculo do IMU é tempo-crítico
  xTaskCreate(TaskLeituraBNO055, "Task BNO", 1024, NULL, 2, NULL); 
  xTaskCreate(TaskTelemetria, "Task Tele", 1024, NULL, 1, NULL);

  // Iniciar o RTOS
  vTaskStartScheduler();
}

void loop() {
  // Vazio, controlado pelo FreeRTOS
}
